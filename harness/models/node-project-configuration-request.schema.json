{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "harness://models/node-project-configuration-request.schema.json",
  "title": "NodeProjectConfigurationRequest",
  "type": "object",
  "required": ["request"],
  "properties": {
    "request": {
      "type": "string",
      "minLength": 1,
      "description": "需要初始化或规范化的 Node.js TypeScript 项目。"
    },
    "projectRoot": {
      "type": "string",
      "minLength": 1,
      "default": ".",
      "description": "目标项目目录，相对路径从 Harness 根目录解析；默认当前目录。"
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    }
  },
  "additionalProperties": false
}
