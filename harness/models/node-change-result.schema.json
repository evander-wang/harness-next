{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "harness://models/node-change-result.schema.json",
  "title": "NodeChangeResult",
  "type": "object",
  "required": ["status", "summary", "changedFiles", "verification", "risks"],
  "properties": {
    "status": {
      "const": "done"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "changedFiles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verification": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
