{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "harness://models/node-project-profile.schema.json",
  "title": "NodeProjectProfile",
  "type": "object",
  "required": [
    "projectState",
    "projectKind",
    "nodeVersion",
    "packageManager",
    "moduleSystem",
    "source",
    "scripts",
    "quality",
    "configuration",
    "optionalCapabilities"
  ],
  "properties": {
    "projectState": {
      "enum": ["new", "existing"]
    },
    "projectKind": {
      "enum": ["service", "cli", "library"]
    },
    "nodeVersion": {
      "type": "string",
      "pattern": "^[0-9]+(?:\\.[0-9]+){0,2}$"
    },
    "packageManager": {
      "type": "object",
      "required": ["name", "version", "detectedBy"],
      "properties": {
        "name": {
          "enum": ["npm", "yarn", "pnpm"]
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "detectedBy": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "moduleSystem": {
      "enum": ["esm", "commonjs"]
    },
    "source": {
      "type": "object",
      "required": ["sourceDir", "testDir", "entrypoints", "outputDir"],
      "properties": {
        "sourceDir": {
          "type": "string",
          "minLength": 1
        },
        "testDir": {
          "type": "string",
          "minLength": 1
        },
        "entrypoints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "outputDir": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "scripts": {
      "type": "object",
      "required": ["typecheck", "lint", "test", "build", "checkAll"],
      "properties": {
        "dev": {
          "type": "string",
          "minLength": 1
        },
        "typecheck": {
          "type": "string",
          "minLength": 1
        },
        "lint": {
          "type": "string",
          "minLength": 1
        },
        "test": {
          "type": "string",
          "minLength": 1
        },
        "build": {
          "type": "string",
          "minLength": 1
        },
        "start": {
          "type": "string",
          "minLength": 1
        },
        "checkAll": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "quality": {
      "type": "object",
      "required": ["strictTypeScript", "noExplicitAny", "testRunner"],
      "properties": {
        "strictTypeScript": {
          "const": true
        },
        "noExplicitAny": {
          "const": true
        },
        "testRunner": {
          "type": "string",
          "minLength": 1
        },
        "dependencyCheck": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "configuration": {
      "type": "object",
      "required": ["environments", "configSource", "validationEntry", "secretPolicy"],
      "properties": {
        "environments": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "configSource": {
          "enum": ["environment", "file", "mixed", "none"]
        },
        "validationEntry": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "secretPolicy": {
          "enum": ["environment-only", "local-untracked-file", "not-applicable"]
        }
      },
      "additionalProperties": false
    },
    "optionalCapabilities": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": ["docker", "database", "logging", "health-check"]
      }
    }
  },
  "additionalProperties": false
}
