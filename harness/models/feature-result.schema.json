{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "harness://models/feature-result.schema.json",
  "title": "FeatureResult",
  "type": "object",
  "required": ["status", "summary", "evidence"],
  "properties": {
    "status": {
      "const": "done"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
